{
  "name": "@gnomon/extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "vite build && vite build --config vite.content.config.ts",
    "dev": "vite build --watch",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@gnomon/core": "workspace:*",
    "@gnomon/shared": "workspace:*",
    "@gnomon/ui": "workspace:*",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.6"
  },
  "devDependencies": {}
}
