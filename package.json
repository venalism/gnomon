{
  "name": "gnomon",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "AI token usage prediction and prompt optimization browser extension.",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "format": "prettier --write .",
    "lint": "eslint . --max-warnings=0",
    "test": "turbo test",
    "test:e2e": "pnpm --filter @gnomon/extension test:e2e",
    "typecheck": "turbo typecheck",
    "zip": "tsx scripts/zip-extension.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.53.2",
    "@types/chrome": "^0.0.313",
    "@types/node": "^22.15.34",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.2.0",
    "jszip": "^3.10.1",
    "playwright": "^1.53.2",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.2",
    "vitest": "^3.2.4"
  }
